# PaperLock deployment configuration — copy to ".env" and fill in.
# The .env file sits next to docker-compose.yml and is read automatically.

# REQUIRED. Strong random key used to sign login tokens. The backend refuses
# to start in production without a strong value (>=16 chars).
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Optional. Host port the app is served on (nginx). Default 3000.
FRONTEND_PORT=3000

# Optional. Comma-separated extra CORS origins. Not needed for the bundled
# deployment (frontend + API are same-origin behind nginx). Only set this if
# you serve the frontend from a different origin than the API.
# CORS_ORIGINS=https://paperlock.ucsd.edu

# --- First-run bootstrap (used by `python seed.py`, not docker-compose) ---
# Pin the instructor's first-login access code (otherwise a random one is
# printed once when you run seed.py). PID defaults to INSTRUCTOR.
# INSTRUCTOR_CODE=
# INSTRUCTOR_PID=INSTRUCTOR
# INSTRUCTOR_NAME=Thomas Morton
